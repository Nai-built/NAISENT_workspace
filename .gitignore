# Ignore only JSON files inside the DATA directory
DATA/**/*.json

# Ignore only JSON files inside the SHOWCASES directory
SHOWCASES/**/*.json

# Ignore all folders named "build" anywhere in the project
build/
**/build/

# Ignore all Python cache directories and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Object and build folders generated by the 'dotnet build' command
bin/
obj/

# VS Code specific settings and workspace caches
.vscode/
.history/
*.code-workspace

# Ignore raw DLL binaries and user execution environments
*.dll
*.exe
*.suo
*.user

# Nvidia CUDA local caches and diagnostic logs
*.nvuser
*.nvvp
*.nsight

# Local configuration files containing your PC's specific paths
appsettings.json
config.json
